{
  "include": ["src"],
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "build",
    "target": "esnext",
    "lib": ["esnext"],
    "types": ["node"],
    "declaration": true,
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "sourceMap": true,
    "inlineSources": true,
    "strict": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
