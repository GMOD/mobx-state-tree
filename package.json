{
  "name": "@jbrowse/mobx-state-tree",
  "version": "5.10.1",
  "description": "Fork of mobx-state-tree starting from v5.4.2 for use in jbrowse 2",
  "types": "./dist/index.d.ts",
  "main": "./dist/mobx-state-tree.cjs",
  "module": "./dist/mobx-state-tree.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/mobx-state-tree.mjs",
      "require": "./dist/mobx-state-tree.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "lint": "eslint --report-unused-disable-directives --max-warnings 0",
    "clean": "rimraf dist lib",
    "prebuild": "pnpm clean",
    "format": "pnpm prettier --write .",
    "build": "tsc && rollup -c",
    "test": "vitest",
    "test-ci": "pnpm test:dev --run && pnpm test:prod --run",
    "test:dev": "cross-env NODE_ENV=development vitest",
    "test:prod": "cross-env NODE_ENV=production vitest",
    "prebench": "./scripts/build-both-branches.sh",
    "bench": "cross-env NODE_ENV=production vitest bench --run",
    "preversion": "pnpm build && pnpm test-ci",
    "postversion": "git push --follow-tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GMOD/mobx-state-tree.git"
  },
  "author": "Michel Weststrate",
  "license": "MIT",
  "files": [
    "dist/"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.0",
    "eslint-plugin-import": "^2.32.0",
    "mobx": "^6.15.3",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.4",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-sourcemaps2": "^0.5.7",
    "spec.ts": "^1.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "mobx": "^6.3.0"
  },
  "keywords": [
    "mobx",
    "mobx-state-tree",
    "promise",
    "reactive",
    "frp",
    "functional-reactive-programming",
    "state management"
  ],
  "publishConfig": {
    "access": "public"
  }
}
