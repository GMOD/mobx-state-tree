{
  "name": "@jbrowse/mobx-state-tree",
  "version": "5.6.10",
  "description": "Fork of mobx-state-tree starting from v5.4.2 for use in jbrowse 2",
  "type": "module",
  "types": "esm/index.d.ts",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "lint": "eslint --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write .",
    "build:esm": "tsc",
    "build:cjs": "tsc --module commonjs --moduleResolution bundler --outDir dist",
    "postbuild:cjs": "echo '{\"type\": \"commonjs\"}' > dist/package.json",
    "build": "rm -rf esm dist && pnpm build:esm && pnpm build:cjs",
    "test": "vitest",
    "test-ci": "pnpm test:dev --run && pnpm test:prod --run",
    "test:dev": "NODE_ENV=development vitest",
    "test:prod": "NODE_ENV=production vitest",
    "prebench": "./scripts/build-both-branches.sh",
    "bench": "NODE_ENV=production vitest bench --run",
    "preversion": "pnpm build && pnpm test-ci",
    "postversion": "git push --follow-tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GMOD/mobx-state-tree.git"
  },
  "author": "Michel Weststrate",
  "license": "MIT",
  "files": [
    "esm",
    "dist"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-plugin-import": "^2.32.0",
    "mobx": "^6.15.3",
    "prettier": "^3.8.3",
    "spec.ts": "^1.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "mobx": "^6.3.0"
  },
  "keywords": [
    "mobx",
    "mobx-state-tree",
    "promise",
    "reactive",
    "frp",
    "functional-reactive-programming",
    "state management"
  ],
  "publishConfig": {
    "access": "public"
  }
}
